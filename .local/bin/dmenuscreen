#!/bin/sh

# Use this script to change resolution and refresh
# rate (bandaid fix until I get displayport)
case "$(printf "1080p\\n1440p\\n4k" | dmenu -i -p "Select resolution?")" in
	"1080p") xrandr --output HDMI-1 --primary --mode 1920x1080 --rate 120 --set "Broadcast RGB" "Full" >/dev/null 2>&1 ;;
	"1440p") xrandr --output HDMI-1 --primary --mode 2560x1440 --rate 59.95 --set "Broadcast RGB" "Full" >/dev/null 2>&1 ;;
	"4k") xrandr --output HDMI-1 --primary --mode 3840x2160 --rate 30 --set "Broadcast RGB" "Full" >/dev/null 2>&1 ;;
esac
